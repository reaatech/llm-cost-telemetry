{
  "name": "llm-cost-telemetry",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade LLM cost telemetry — multi-tenant cost tracking, provider SDK wrapping, and observability export",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "keywords": [
    "llm",
    "cost",
    "telemetry",
    "opentelemetry",
    "cloudwatch",
    "monitoring",
    "mcp",
    "openai",
    "anthropic",
    "google"
  ],
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "packageManager": "pnpm@10.22.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/llm-cost-telemetry.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/llm-cost-telemetry/issues"
  },
  "homepage": "https://github.com/reaatech/llm-cost-telemetry#readme",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.28.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
