{
  "name": "@reaatech/llm-cost-telemetry-calculator",
  "version": "0.1.0",
  "description": "Cost calculation engine for LLM API usage — pricing, token counting, and cost estimation",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/llm-cost-telemetry.git",
    "directory": "packages/calculator"
  },
  "homepage": "https://github.com/reaatech/llm-cost-telemetry/tree/main/packages/calculator#readme",
  "bugs": {
    "url": "https://github.com/reaatech/llm-cost-telemetry/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/llm-cost-telemetry": "workspace:*",
    "tiktoken": "^1.0.15"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
